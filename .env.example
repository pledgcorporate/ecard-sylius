# ============================================================
# Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# .env is gitignored and will never be committed.
# ============================================================

# Project identity — used for container names, network, and Traefik router names.
# Must be unique across your local projects.
APP_NAME=sylius

# Local domain — must be added to /etc/hosts → 127.0.0.1
# Mailpit will be available at mail.<APP_DOMAIN>
APP_DOMAIN=sylius.docker

# Symfony environment
APP_ENV=dev
APP_SECRET=change-me-in-production-za3wixvjiq27m6677c4o46niv4g5fz54

# Traefik shared network (must match local-network-multisite configuration)
TRAEFIK_NETWORK=traefik-net

# Traefik Docker image tag.
# See https://hub.docker.com/_/traefik for available tags.
TRAEFIK_IMAGE=traefik:v3.6

# Traefik log verbosity.
# Valid values: DEBUG, INFO, WARN, ERROR
TRAEFIK_LOG_LEVEL=INFO

# Database credentials
DB_ROOT_PASSWORD=root
DB_NAME=sylius
DB_USER=sylius
DB_PASSWORD=sylius
