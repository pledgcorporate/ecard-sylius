# dev environment
.env*
!.env.example

# sylius / symfony application files (created by make install)
/sylius_installation/
/vendor/
/node_modules/
/var/
/public/build/
/public/bundles/

# TLS certificates — generated locally via mkcert, used by traefik, never committed
/.docker/traefik/certs/*.crt
/.docker/traefik/certs/*.key
/.docker/traefik/certs/*.pem

# Keep the certs directory itself tracked
!/certs/.gitkeep

# IDE
/.idea/
/.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

